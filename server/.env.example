# ──────────────────────────────────────────────
# GymFlow Pro — Server Environment Template
# Copy this to .env and fill in your values
# ──────────────────────────────────────────────

NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/gymflow?retryWrites=true&w=majority

# JWT Auth Secrets — generate strong random strings for production
JWT_SECRET=replace_with_strong_secret
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# QR Token Signing Secret
QR_SECRET=replace_with_strong_qr_secret

# Cloudinary (optional — for profile image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SendGrid (optional — for email notifications)
SENDGRID_API_KEY=

# Stripe (optional — for payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Razorpay (optional — alternative payment gateway)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
