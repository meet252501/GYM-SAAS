# Server Configuration
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# Database
MONGO_URI=mongodb://127.0.0.1:27017/gymflow_production

# Authentication
JWT_SECRET=your_super_secret_jwt_key_here
JWT_REFRESH_SECRET=your_refresh_secret_key_here
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# QR Token Secret
QR_SECRET=your_qr_signing_secret_here

# Email Service (SMTP)
EMAIL_HOST=smtp.ethereal.email
EMAIL_PORT=587
EMAIL_USER=your_smtp_user
EMAIL_PASS=your_smtp_password
EMAIL_FROM=noreply@gymflow.com
GYM_NAME=GymFlow Pro

# Payment Gateways
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Dodo Payments
DODO_API_KEY=sk_test_...
DODO_ENVIRONMENT=test_mode
DODO_WEBHOOK_KEY=whsec_test_...
# AI Integrations# SendGrid / SMTP (optional)
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USER=apikey
EMAIL_PASS=
EMAIL_FROM=noreply@gymflow.com

# Firebase Admin SDK (for Push Notifications)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

GROQ_API_KEY=
GEMINI_API_KEY=_vision_key_here
